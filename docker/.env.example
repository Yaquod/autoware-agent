# Copy to docker/.env and fill in for your vehicle/edge unit.
#   cp docker/.env.example docker/.env

# ---- Images (pulled on the edge, built & pushed off-edge) -------------------
AUTOWARE_IMAGE=ghcr.io/yaquod/autoware:universe-cuda
AGENT_IMAGE=ghcr.io/yaquod/autoware-agent:latest

# ---- Autoware launch --------------------------------------------------------
# Path on the Jetson to the lanelet2 + pointcloud map directory (mounted read-only).
MAP_PATH=/opt/autoware_map/my_map
# Real-vehicle launch. For a bench/sim bring-up use planning_simulator.launch.xml.
AUTOWARE_LAUNCH=autoware.launch.xml
VEHICLE_MODEL=sample_vehicle
SENSOR_MODEL=sample_sensor_kit

# ---- ROS 2 / DDS ------------------------------------------------------------
# Both containers must share this so they discover each other over the host net.
ROS_DOMAIN_ID=0

# ---- Agent ------------------------------------------------------------------
# External gateway (cloud/fleet) endpoint the agent streams to, if applicable.
GATEWAY_ADDR=
# Host dir mounted at /opt/agent/config for route/map overrides (optional).
AGENT_CONFIG_DIR=./agent-config
