ARG AUTOWARE_IMAGE=ghcr.io/autowarefoundation/autoware:universe-devel
FROM ${AUTOWARE_IMAGE}

ARG CLANG_VERSION=17
ARG DEBIAN_FRONTEND=noninteractive

LABEL maintainer="Ahmed Wafdy"
LABEL description="AutowareAgent CI image with clang, tidy, format, coverage tools"

RUN apt-get update -qq && apt-get install -y --no-install-recommends \
    git cmake build-essential autoconf libtool curl ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# Protobuf
RUN git clone --branch v3.21.12 --depth 1 https://github.com/protocolbuffers/protobuf.git /tmp/protobuf \
    && cd /tmp/protobuf \
    && git submodule update --init --recursive \
    && mkdir build && cd build \
    && cmake .. -DCMAKE_BUILD_TYPE=Release -DCMAKE_POSITION_INDEPENDENT_CODE=ON -DCMAKE_INSTALL_PREFIX=/usr/local \
    && make -j$(nproc) \
    && make install \
    && ldconfig \
    && cd ../.. && rm -rf /tmp/protobuf

# gRPC
RUN git clone --recurse-submodules -b v1.60.0 --depth 1 https://github.com/grpc/grpc /tmp/grpc \
    && cd /tmp/grpc \
    && mkdir -p cmake/build && cd cmake/build \
    && cmake ../.. -DCMAKE_BUILD_TYPE=Release -DgRPC_INSTALL=ON -DCMAKE_INSTALL_PREFIX=/usr/local -DgRPC_BUILD_TESTS=OFF \
    && make -j$(nproc) \
    && make install \
    && ldconfig \
    && cd ../../../ && rm -rf /tmp/grpc

# Zenoh and Zenoh-cxx
RUN curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y \
    && export PATH="/root/.cargo/bin:${PATH}" \
    && git clone --depth 1 https://github.com/eclipse-zenoh/zenoh-c.git /tmp/zenoh-c \
    && cd /tmp/zenoh-c \
    && cmake -Bbuild -DCMAKE_BUILD_TYPE=Release -DCMAKE_INSTALL_PREFIX=/usr/local \
    && cmake --build build --target install -j$(nproc) \
    && git clone --depth 1 https://github.com/eclipse-zenoh/zenoh-cpp.git /tmp/zenoh-cpp \
    && cd /tmp/zenoh-cpp \
    && cmake -Bbuild -DCMAKE_BUILD_TYPE=Release -DCMAKE_INSTALL_PREFIX=/usr/local \
    && cmake --build build --target install -j$(nproc) \
    && cd / \
    && rm -rf /tmp/zenoh-c /tmp/zenoh-cpp \
    && rustup self uninstall -y

RUN apt-get update -qq && apt-get install -y --no-install-recommends \
    wget gnupg lsb-release \
    && wget -qO- https://apt.llvm.org/llvm-snapshot.gpg.key | tee /etc/apt/trusted.gpg.d/apt.llvm.org.asc \
    && echo "deb http://apt.llvm.org/jammy/ llvm-toolchain-jammy-${CLANG_VERSION} main" > /etc/apt/sources.list.d/llvm.list \
    && apt-get update -qq && apt-get install -y --no-install-recommends \
    # Clang toolchain
    clang-${CLANG_VERSION} \
    clang-format-${CLANG_VERSION} \
    clang-tidy-${CLANG_VERSION} \
    lld-${CLANG_VERSION} \
    llvm-${CLANG_VERSION} \
    libclang-rt-${CLANG_VERSION}-dev \
    libomp-${CLANG_VERSION}-dev \
    # Build tools
    ninja-build \
    ccache \
    pkg-config \
    # Autoware Agent C++ Dependencies
    libyaml-cpp-dev \
    libgmock-dev \
    libgtest-dev \
    libboost-system-dev \
    ros-humble-fastcdr \
    # Coverage & Utilities
    gcovr \
    jq \
    python3-pip \
    && rm -rf /var/lib/apt/lists/*

RUN for tool in clang clang++ clang-format clang-tidy; do \
      ln -sf "/usr/bin/${tool}-${CLANG_VERSION}" "/usr/local/bin/${tool}"; \
    done

RUN apt-get update -qq && apt-get install -y --no-install-recommends \
    cpanminus \
    libperlio-gzip-perl \
    libjson-perl \
    && cpanm --notest --quiet \
    Capture::Tiny DateTime Date::Parse Digest::MD5 File::Spec Memory::Process Storable JSON::XS \
    && rm -rf /var/lib/apt/lists/*

RUN wget -qO /tmp/lcov.tar.gz https://github.com/linux-test-project/lcov/releases/download/v2.1/lcov-2.1.tar.gz \
    && tar -xzf /tmp/lcov.tar.gz -C /tmp \
    && make -C /tmp/lcov-2.1 install PREFIX=/usr/local -j$(nproc) \
    && rm -rf /tmp/lcov*

RUN printf '#!/bin/bash\nexec llvm-cov-%s gcov "$@"\n' "${CLANG_VERSION}" > /usr/local/bin/llvm-gcov \
    && chmod +x /usr/local/bin/llvm-gcov

RUN pip3 install --no-cache-dir \
    colcon-common-extensions \
    colcon-mixin \
    vcstool \
    pre-commit \
    pytest \
    pytest-xdist

ENV CCACHE_DIR=/ccache
ENV CCACHE_MAXSIZE=5G
ENV CCACHE_COMPRESS=1
RUN mkdir -p /ccache && chmod 777 /ccache

SHELL ["/bin/bash", "-c"]
RUN echo "source /opt/ros/humble/setup.bash" >> /etc/bash.bashrc

WORKDIR /workspace

COPY docker/entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh
ENTRYPOINT ["/entrypoint.sh"]
CMD ["bash"]